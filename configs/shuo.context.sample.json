{
  "version": 1,
  "recognition": {
    "enable_punctuation": true,
    "enable_speech_rejection": false
  },
  "hotwords": [
    "豆包",
    "OpenAI",
    "Cursor"
  ],
  "user_terms": [
    "SAMI",
    "BiStream",
    "Cronet"
  ],
  "text_context": {
    "mode": "auto",
    "max_chars": 256,
    "text": "",
    "cursor_position": 0
  },
  "ime_context": {
    "input_type": "default"
  },
  "feedback": {
    "start_sound": "jbl_begin_short.caf",
    "stop_sound": "Pop.aiff"
  },
  "advanced": {
    "use_user_dictionary": true,
    "enable_text_filter": true,
    "enable_asr_twopass": true,
    "enable_asr_threepass": true,
    "remove_space_between_han_eng": true,
    "remove_space_between_han_num": true,
    "strong_ddc": false
  }
}
